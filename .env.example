# Local: copy to `.env.local`. Production: add the same keys in Vercel → your project → Settings → Environment Variables
# (Production / Preview / Development as needed). Redeploy after changing secrets. Server-only vars stay server-side on Vercel.

# --- Google Search Console (HTML tag method) ---
# In Search Console → Add property → URL prefix → HTML tag, copy only the `content` value (not the whole tag).
GOOGLE_SITE_VERIFICATION=

# --- Google Business Profile (Maps / GBP) ---
# Your public Google Business Profile URL (short maps link or “Share” URL). Used in JSON-LD sameAs and optional footer button.
NEXT_PUBLIC_GOOGLE_BUSINESS_PROFILE_URL=

# --- Cloudflare Images (also set these in Vercel; homepage reads them at runtime) ---
# Image Delivery hash: Cloudflare Dashboard → Images → Developer Resources. NEXT_PUBLIC_* is inlined at build but safe (public hash only).
NEXT_PUBLIC_CF_IMAGES_HASH=
# Optional: variant name (default "public")
# CF_IMAGES_VARIANT=public
#
# Private images: Dashboard → Images → signature token (server-only). If set, delivery URLs include exp + sig (HMAC).
# Rotate the token in Cloudflare if it was ever committed or pasted into chat.
# CLOUDFLARE_IMAGES_SIGNING_KEY=
# Optional TTL for signed URLs in seconds (default 86400 = 24h).
# CF_IMAGES_SIGNED_URL_TTL_SECONDS=86400
#
# To pull photos automatically: set HASH + ACCOUNT_ID + API token below (token needs Account → Images → Read).
# Newest 11 images in the account map to: hero, 6 property-grid, 3 gallery, 1 floor plan.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# (Alias: CLOUDFLARE_GLOBAL_API_TOKEN is used if CLOUDFLARE_API_TOKEN is unset — same token, fleet naming.)
#
# Optional: comma-separated image IDs in that exact order (overrides auto order for those slots).
# CLOUDFLARE_IMAGE_IDS=
#
# If CLOUDFLARE_IMAGE_IDS is partially set, set CLOUDFLARE_SYNC_FROM_API=true so the API fills remaining slots.
# Set CLOUDFLARE_SYNC_FROM_API=false to never call the list-images API (hash + manual IDs only).
# CLOUDFLARE_SYNC_FROM_API=
