# Copy to `.env.local` for local dev. Production: Vercel → Project → Settings → Environment Variables
# (set per environment: Production / Preview / Development). Redeploy after changes.

# =============================================================================
# Vercel checklist — maps to code in this repo
# =============================================================================
#
# | Goal                         | Variable(s)                          | Read by                          |
# |------------------------------|--------------------------------------|----------------------------------|
# | Search Console HTML tag      | GOOGLE_SITE_VERIFICATION             | lib/metadata.ts                  |
# | Footer “GBP” + JSON-LD sameAs| NEXT_PUBLIC_GOOGLE_BUSINESS_PROFILE_URL | lib/site-contact.ts (getAgentSameAsUrls, footer) |
# | Cloudflare delivery URLs     | NEXT_PUBLIC_CF_IMAGES_HASH (or CF_IMAGES_HASH) | lib/cloudflare-images.ts |
# | List images / fill slots     | CLOUDFLARE_ACCOUNT_ID + CLOUDFLARE_API_TOKEN (or CLOUDFLARE_GLOBAL_API_TOKEN) | lib/cloudflare-images.ts |
# | Private/signed images        | CLOUDFLARE_IMAGES_SIGNING_KEY        | lib/cloudflare-images.ts         |
#
# =============================================================================

# --- Google Search Console (HTML tag method) ---
# Search Console → Add property → URL prefix → HTML tag → copy only the `content` value (not the whole tag).
GOOGLE_SITE_VERIFICATION=

# --- Google Business Profile (Maps / GBP) ---
# Must match the live Maps/GBP listing for NAP consistency. Examples: “Share” link from Business Profile Manager,
# or Maps place URL for the business. Used in footer button + JSON-LD `sameAs` (see getAgentSameAsUrls).
NEXT_PUBLIC_GOOGLE_BUSINESS_PROFILE_URL=

# --- Cloudflare Images (homepage reads at runtime; see lib/cloudflare-images.ts) ---
# Delivery hash: Cloudflare Dashboard → Images → Developer Resources.
NEXT_PUBLIC_CF_IMAGES_HASH=
# Alternative server-only name (same value as NEXT_PUBLIC_* if you prefer not to expose the prefix):
# CF_IMAGES_HASH=

# Optional variant (default "public").
# CF_IMAGES_VARIANT=public

# Private images: Dashboard → Images → signing key (server-only). Never commit the real key.
# CLOUDFLARE_IMAGES_SIGNING_KEY=
# CF_IMAGES_SIGNED_URL_TTL_SECONDS=86400

# Account API (list images, auto-fill): Account ID + API token with Images → Read.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_GLOBAL_API_TOKEN=

# Optional: comma-separated image IDs in order — hero, 6 grid, 3 gallery, 1 floor plan (11 total).
# CLOUDFLARE_IMAGE_IDS=

# If IDs are partial, set true to fill remaining slots from API. Set false to disable API listing.
# CLOUDFLARE_SYNC_FROM_API=
